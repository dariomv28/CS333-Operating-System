+void
+print_lineno(int n)
+{
+  int digits = 0;
+  int t = n;
+
+  if(t == 0) digits = 1;
+  while(t > 0){
+    digits++;
+    t /= 10;
+  }
+
+  // print leading spaces
+  for(int i = 0; i < 6 - digits; i++)
+    printf(" ");
+
+  printf("%d  ", n);
