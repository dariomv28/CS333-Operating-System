+int
+getprocs(uint64 addr, int n) 
+{
+  struct proc* p;
+  struct procinfo info;
+  int count = 0;
+
+  for (p = proc; p < &proc[NPROC]; p++) {
+    if (p->state == UNUSED) {
+      continue;
+    }
+    if (count >= n) {
+      break;
+    }
+    info.pid = p->pid;
+    info.state = p->state;
+    info.sz = p->sz;
+    safestrcpy(info.name, p->name, sizeof(info.name));
+
+    if (copyout(myproc()->pagetable, addr + count * sizeof(info), (char*)&info, sizeof(info)) < 0) {
+      return -1;
+    }
+
+    count++;
+  }
+  return count;
+}
